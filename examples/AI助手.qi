// qi-cli 复杂示例 5：AI 助手 — qi-cli + qi-harness 端到端整合
//
// 子命令：
//   AI助手 问 <提示>                 — 一次性问答
//   AI助手 流 <提示>                 — 流式输出
//   AI助手 翻译 <文本> [--目标 X]    — 翻译到指定语言（默认英文）
//   AI助手 总结 <文本>               — 一句话总结
//
// 环境：需要 QI_LLM_KEY，使用 DeepSeek 兼容 OpenAI 端点。
// 跑：QI_LLM_KEY=sk-... qi run AI助手.qi 问 "你好"

包 主程序;

导入 标准库.输入输出 作为 IO;
导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 简单问, 流式问, 运行, 关闭代理,
    装备MCP, 连接MCP_stdio, 关闭MCP
};
导入 Harness.追踪 作为 追踪;
导入 CLI::{
    创建应用, 创建命令, 创建参数, 执行,
    应用版本, 应用作者, 应用简介, 应用执行,
    应用添加命令,
    命令简介, 命令示例, 命令执行,
    命令添加参数, 命令添加别名,
    参数长名, 参数短名, 参数帮助, 参数默认值,
    值
};

// 流块回调：每片段立刻打到 stdout（不换行）
函数 打印片段(片段: 字符串) : 整数 {
    IO.打印(片段);
    返回 1;
}

函数 取密钥(): 字符串 {
    返回 系统.获取环境变量("QI_LLM_KEY");
}

函数 创建会话(系统提示: 字符串) : 整数 {
    变量 密钥: 字符串 = 取密钥();
    如果 (字符串::字节长度(密钥) == 0) {
        IO.打印行("未设 QI_LLM_KEY");
        返回 -1;
    }
    变量 配置: 模型配置 = 大模型("https://api.deepseek.com", 密钥, "deepseek-chat");
    配置 = 配置系统提示(配置, 系统提示);
    返回 开启会话(配置);
}

// MCP 默认接入：配置了 QI_MCP_命令 就自动连上该 MCP 服务器，返回描述符；
// 未配置返回空串（此时助手照常回答，只是没有外部工具）。
//   QI_MCP_命令  例如 npx
//   QI_MCP_参数  JSON 数组，例如 ["-y","@modelcontextprotocol/server-filesystem","."]
函数 连接默认MCP() : 字符串 {
    变量 命令: 字符串 = 系统.获取环境变量("QI_MCP_命令");
    如果 (字符串::字节长度(命令) == 0) { 返回 ""; }
    变量 参数: 字符串 = 系统.获取环境变量("QI_MCP_参数");
    如果 (字符串::字节长度(参数) == 0) { 参数 = "[]"; }
    返回 连接MCP_stdio(命令, 参数);
}

函数 根执行(上下文值: 上下文) : 整数 {
    IO.打印行("AI助手 — 用 --help 查看子命令");
    IO.打印行("先设 QI_LLM_KEY 环境变量");
    IO.打印行("MCP：设 QI_MCP_命令 后「问」会自动带上工具；或直接用「mcp」子命令");
    返回 0;
}

// mcp 子命令：显式接一个 MCP 服务器，让 AI 用它的工具完成任务。
// 默认连 server-everything（自带 echo/add 等演示工具），可用 --服务器/--参数 覆盖。
函数 执行mcp(上下文值: 上下文) : 整数 {
    变量 提示: 字符串 = 值(上下文值, "提示");
    如果 (字符串::字节长度(提示) == 0) {
        IO.打印行("用法: AI助手 mcp <提示> [--服务器 npx] [--参数 '[\"-y\",\"@modelcontextprotocol/server-everything\"]']");
        返回 1;
    }
    变量 服务器: 字符串 = 值(上下文值, "服务器");
    如果 (字符串::字节长度(服务器) == 0) { 服务器 = "npx"; }
    变量 参数: 字符串 = 值(上下文值, "参数");
    如果 (字符串::字节长度(参数) == 0) {
        参数 = "[\"-y\",\"@modelcontextprotocol/server-everything\"]";
    }
    追踪.禁用即时打印();
    变量 会话: 整数 = 创建会话("你是助手，可以调用 MCP 服务器提供的工具，优先用工具完成任务。");
    如果 (会话 <= 0) { 返回 1; }
    变量 mcp: 字符串 = 连接MCP_stdio(服务器, 参数);
    如果 (字符串::字节长度(mcp) == 0) {
        IO.打印行("连接 MCP 服务器失败：" + 服务器 + " " + 参数);
        IO.打印行("确认本机能跑该命令（多数需要 npx / node），或换 --服务器 / --参数。");
        返回 1;
    }
    变量 代理值: 代理 = 创建代理("MCP助手", 会话);
    代理值 = 装备MCP(代理值, mcp);
    变量 回复: 字符串 = 运行(代理值, 提示);
    IO.打印行(回复);
    关闭MCP(mcp);
    关闭代理(代理值);
    返回 0;
}

函数 执行问(上下文值: 上下文) : 整数 {
    变量 提示: 字符串 = 值(上下文值, "提示");
    如果 (字符串::字节长度(提示) == 0) {
        IO.打印行("用法: AI助手 问 <提示>");
        返回 1;
    }
    追踪.禁用即时打印();
    变量 会话: 整数 = 创建会话("你是简洁的中文助手，回答尽量短。有工具可用时优先用工具查真实信息。");
    如果 (会话 <= 0) { 返回 1; }
    变量 代理值: 代理 = 创建代理("问答", 会话);
    // MCP 默认接入：配了 QI_MCP_命令 就自动挂上该服务器的工具，AI 可自行调用
    变量 mcp: 字符串 = 连接默认MCP();
    变量 有MCP: 整数 = 0;
    如果 (字符串::字节长度(mcp) > 0) {
        代理值 = 装备MCP(代理值, mcp);
        有MCP = 1;
    }
    变量 回复: 字符串 = "";
    如果 (有MCP == 1) {
        回复 = 运行(代理值, 提示);
    } 否则 {
        回复 = 简单问(代理值, 提示);
    }
    IO.打印行(回复);
    如果 (有MCP == 1) { 关闭MCP(mcp); }
    关闭代理(代理值);
    返回 0;
}

函数 执行流(上下文值: 上下文) : 整数 {
    变量 提示: 字符串 = 值(上下文值, "提示");
    如果 (字符串::字节长度(提示) == 0) {
        IO.打印行("用法: AI助手 流 <提示>");
        返回 1;
    }
    追踪.禁用即时打印();
    变量 会话: 整数 = 创建会话("你是简洁的中文助手。");
    如果 (会话 <= 0) { 返回 1; }
    变量 代理值: 代理 = 创建代理("流式", 会话);
    流式问(代理值, 提示, 打印片段);
    IO.打印行("");
    关闭代理(代理值);
    返回 0;
}

函数 执行翻译(上下文值: 上下文) : 整数 {
    变量 文本: 字符串 = 值(上下文值, "文本");
    如果 (字符串::字节长度(文本) == 0) {
        IO.打印行("用法: AI助手 翻译 <文本> [--目标 英文|日文|...]");
        返回 1;
    }
    变量 目标: 字符串 = 值(上下文值, "目标");
    如果 (字符串::字节长度(目标) == 0) {
        目标 = "英文";
    }
    追踪.禁用即时打印();
    变量 会话: 整数 = 创建会话("你是专业翻译，只输出翻译结果不解释。");
    如果 (会话 <= 0) { 返回 1; }
    变量 代理值: 代理 = 创建代理("翻译", 会话);
    变量 提示: 字符串 = "把下面这段翻译成" + 目标 + "：\n" + 文本;
    变量 回复: 字符串 = 简单问(代理值, 提示);
    IO.打印行(回复);
    关闭代理(代理值);
    返回 0;
}

函数 执行总结(上下文值: 上下文) : 整数 {
    变量 文本: 字符串 = 值(上下文值, "文本");
    如果 (字符串::字节长度(文本) == 0) {
        IO.打印行("用法: AI助手 总结 <文本>");
        返回 1;
    }
    追踪.禁用即时打印();
    变量 会话: 整数 = 创建会话("你是中文助手，用一句话总结输入。");
    如果 (会话 <= 0) { 返回 1; }
    变量 代理值: 代理 = 创建代理("总结", 会话);
    变量 回复: 字符串 = 简单问(代理值, 文本);
    IO.打印行(回复);
    关闭代理(代理值);
    返回 0;
}

函数 入口() {
    变量 应用值: 应用 = 创建应用("AI助手");
    应用值 = 应用版本(应用值, "0.1.0");
    应用值 = 应用作者(应用值, "Qi Examples");
    应用值 = 应用简介(应用值, "qi-cli + qi-harness 接 DeepSeek，做问答 / 流 / 翻译 / 总结，默认支持 MCP 工具");
    应用值 = 应用执行(应用值, 根执行);

    // ---- 问 ----
    变量 问命令: 命令 = 创建命令("问");
    问命令 = 命令简介(问命令, "一次性问答");
    问命令 = 命令示例(问命令, "AI助手 问 \"qi 是什么\"");
    问命令 = 命令添加别名(问命令, "ask");
    问命令 = 命令执行(问命令, 执行问);
    变量 提示参数1: 参数 = 创建参数("提示");
    提示参数1 = 参数帮助(提示参数1, "问题文本");
    问命令 = 命令添加参数(问命令, 提示参数1);
    应用值 = 应用添加命令(应用值, 问命令);

    // ---- 流 ----
    变量 流命令: 命令 = 创建命令("流");
    流命令 = 命令简介(流命令, "流式问答（实时输出）");
    流命令 = 命令示例(流命令, "AI助手 流 \"用三句话解释 LLVM\"");
    流命令 = 命令添加别名(流命令, "stream");
    流命令 = 命令执行(流命令, 执行流);
    变量 提示参数2: 参数 = 创建参数("提示");
    提示参数2 = 参数帮助(提示参数2, "问题文本");
    流命令 = 命令添加参数(流命令, 提示参数2);
    应用值 = 应用添加命令(应用值, 流命令);

    // ---- 翻译 ----
    变量 翻译命令: 命令 = 创建命令("翻译");
    翻译命令 = 命令简介(翻译命令, "翻译到指定语言");
    翻译命令 = 命令示例(翻译命令, "AI助手 翻译 \"你好\" --目标 日文");
    翻译命令 = 命令添加别名(翻译命令, "tr");
    翻译命令 = 命令执行(翻译命令, 执行翻译);
    变量 文本参数1: 参数 = 创建参数("文本");
    文本参数1 = 参数帮助(文本参数1, "原文");
    翻译命令 = 命令添加参数(翻译命令, 文本参数1);
    变量 目标参数: 参数 = 创建参数("目标");
    目标参数 = 参数长名(目标参数, "目标");
    目标参数 = 参数短名(目标参数, "t");
    目标参数 = 参数帮助(目标参数, "目标语言（默认英文）");
    目标参数 = 参数默认值(目标参数, "英文");
    翻译命令 = 命令添加参数(翻译命令, 目标参数);
    应用值 = 应用添加命令(应用值, 翻译命令);

    // ---- 总结 ----
    变量 总结命令: 命令 = 创建命令("总结");
    总结命令 = 命令简介(总结命令, "一句话总结");
    总结命令 = 命令执行(总结命令, 执行总结);
    变量 文本参数2: 参数 = 创建参数("文本");
    文本参数2 = 参数帮助(文本参数2, "要总结的内容");
    总结命令 = 命令添加参数(总结命令, 文本参数2);
    应用值 = 应用添加命令(应用值, 总结命令);

    // ---- mcp ----
    变量 mcp命令: 命令 = 创建命令("mcp");
    mcp命令 = 命令简介(mcp命令, "接一个 MCP 服务器，让 AI 用它的工具作答");
    mcp命令 = 命令示例(mcp命令, "AI助手 mcp \"用 echo 工具回显 hello world\"");
    mcp命令 = 命令执行(mcp命令, 执行mcp);
    变量 mcp提示: 参数 = 创建参数("提示");
    mcp提示 = 参数帮助(mcp提示, "要 AI 借助 MCP 工具完成的任务");
    mcp命令 = 命令添加参数(mcp命令, mcp提示);
    变量 服务器参数: 参数 = 创建参数("服务器");
    服务器参数 = 参数长名(服务器参数, "服务器");
    服务器参数 = 参数短名(服务器参数, "s");
    服务器参数 = 参数帮助(服务器参数, "MCP 启动命令（默认 npx）");
    服务器参数 = 参数默认值(服务器参数, "npx");
    mcp命令 = 命令添加参数(mcp命令, 服务器参数);
    变量 参数参数: 参数 = 创建参数("参数");
    参数参数 = 参数长名(参数参数, "参数");
    参数参数 = 参数帮助(参数参数, "MCP 命令参数（JSON 数组，默认 server-everything）");
    mcp命令 = 命令添加参数(mcp命令, 参数参数);
    应用值 = 应用添加命令(应用值, mcp命令);

    执行(应用值);
}
